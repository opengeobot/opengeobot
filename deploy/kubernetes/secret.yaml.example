# Function: Example Secret manifest — replace placeholders; do NOT commit real secrets
# Time: 2026-07-10
# Author: AxeXie
#
# Usage:
#   cp secret.yaml.example secret.yaml
#   # edit values (prefer sealed-secrets / external-secrets in real clusters)
#   kubectl apply -f secret.yaml
#
# This file is an EXAMPLE only. Real credentials must never be committed.
apiVersion: v1
kind: Secret
metadata:
  name: opengeobot-secrets
  namespace: opengeobot
  labels:
    app.kubernetes.io/part-of: opengeobot
type: Opaque
stringData:
  DB_PASSWORD: "CHANGE_ME_db_password"
  MINIO_ROOT_USER: "CHANGE_ME_minio_user"
  MINIO_ROOT_PASSWORD: "CHANGE_ME_minio_password"
