# =============================================================================
# OpenGeoBot — Environment Configuration Template
# Time: 2026-07-03
# Author: AxeXie
#
# Copy to .env and adjust values. Never commit the real .env file.
# Format: VARIABLE=example_value  # [Required|Optional] Purpose. Default: xxx
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL / pgvector
# -----------------------------------------------------------------------------
DB_HOST=localhost                # [Required] PostgreSQL host. Default: localhost
DB_PORT=5432                     # [Required] PostgreSQL port. Default: 5432
DB_NAME=opengeobot               # [Required] Database name. Default: opengeobot
DB_SCHEMA=public                 # [Optional] Default schema. Default: public
DB_USER=opengeobot               # [Required] Database user. Default: opengeobot
DB_PASSWORD=opengeobot_dev       # [Required] Database password. Default: opengeobot_dev (matches docker compose)
DB_POOL_SIZE=10                  # [Optional] HikariCP max pool size. Default: 10
DB_SSL_MODE=disable              # [Optional] PostgreSQL SSL mode. Default: disable (use require in production)

# -----------------------------------------------------------------------------
# NATS JetStream
# -----------------------------------------------------------------------------
NATS_URL=nats://localhost:4222    # [Required] NATS server URL. Default: nats://localhost:4222
NATS_STREAM_PREFIX=opengeobot    # [Optional] JetStream stream name prefix. Default: opengeobot
NATS_MAX_RECONNECT=-1            # [Optional] Max reconnect attempts (-1 = unlimited). Default: -1
NATS_CONNECT_TIMEOUT=5           # [Optional] Connection timeout in seconds. Default: 5

# -----------------------------------------------------------------------------
# MinIO / S3 (Object Storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000   # [Required] MinIO/S3 endpoint URL. Default: http://localhost:9000
MINIO_ACCESS_KEY=opengeobot            # [Required] MinIO access key. Default: opengeobot (matches docker compose)
MINIO_SECRET_KEY=opengeobot_dev    # [Required] MinIO secret key. Default: opengeobot_dev (matches docker compose)
MINIO_BUCKET=opengeobot                # [Required] Default bucket name. Default: opengeobot
MINIO_REGION=us-east-1                 # [Optional] S3 region. Default: us-east-1
MINIO_SECURE=false                     # [Optional] Use TLS. Default: false (true in production)

# -----------------------------------------------------------------------------
# Java Cloud Control Application
# -----------------------------------------------------------------------------
SERVER_PORT=8080                 # [Required] Spring Boot server port. Default: 8080
SPRING_PROFILES_ACTIVE=dev       # [Required] Active Spring profile. Default: dev (use prod in production)
JAVA_OPTS=-Xms512m -Xmx1024m     # [Optional] JVM options. Default: -Xms512m -Xmx1024m
FLYWAY_ENABLED=true              # [Optional] Enable Flyway migration on startup. Default: true
FLYWAY_LOCATIONS=classpath:db/migration  # [Optional] Flyway migration locations. Default: classpath:db/migration

# -----------------------------------------------------------------------------
# Frontend (Vue 3 + Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080/api   # [Required] Cloud control API base URL. Default: http://localhost:8080/api
VITE_WS_BASE_URL=ws://localhost:8080/ws        # [Required] WebSocket base URL for real-time. Default: ws://localhost:8080/ws
VITE_APP_TITLE=OpenGeoBot                       # [Optional] Application title. Default: OpenGeoBot
VITE_API_TIMEOUT=30000                          # [Optional] API request timeout in ms. Default: 30000

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
VICTORIA_METRICS_URL=http://localhost:8428   # [Required] VictoriaMetrics push URL. Default: http://localhost:8428
LOKI_URL=http://localhost:3100               # [Required] Loki log endpoint. Default: http://localhost:3100
GRAFANA_URL=http://localhost:3000            # [Optional] Grafana dashboard URL. Default: http://localhost:3000
VECTOR_CONFIG=deploy/observability/vector.toml  # [Optional] Vector config path. Default: deploy/observability/vector.toml
LOG_LEVEL=INFO                                # [Optional] Application log level. Default: INFO

# -----------------------------------------------------------------------------
# Agent Runtime (Python)
# -----------------------------------------------------------------------------
AGENT_RUNTIME_PORT=8100                       # [Required] Agent runtime service port. Default: 8100
AGENT_RUNTIME_PROVIDER=qwenpaw                 # [Required] Agent runtime provider. Default: qwenpaw
QWENPAW_API_BASE_URL=https://api.qwenpaw.example.com  # [Conditional] QwenPaw API URL (required if provider=qwenpaw)
QWENPAW_API_KEY=change-me                      # [Conditional] QwenPaw API key (required if provider=qwenpaw)

# -----------------------------------------------------------------------------
# Edge / Safety Gateway
# -----------------------------------------------------------------------------
EDGE_GATEWAY_PORT=8200                        # [Required] Edge gateway port. Default: 8200
SAFETY_GATEWAY_PORT=8201                       # [Required] Safety gateway port. Default: 8201
EDGE_LOCAL_SKILL_EXECUTOR_PORT=8202            # [Required] Local skill executor port. Default: 8202
EDGE_ROS_DOMAIN_ID=0                           # [Optional] ROS2 domain ID. Default: 0
EDGE_ZENOH_MODE=peer                           # [Optional] Zenoh mode (peer/client). Default: peer

# -----------------------------------------------------------------------------
# MCP Tool Gateway
# -----------------------------------------------------------------------------
MCP_GATEWAY_PORT=8300                         # [Required] MCP tool gateway port. Default: 8300
MCP_AUTH_TOKEN=change-me-in-prod              # [Required] MCP gateway auth token. Default: change-me-in-prod

# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=opengeobot               # [Optional] Docker Compose project name. Default: opengeobot
COMPOSE_DATA_DIR=./.docker-data               # [Optional] Docker volume data directory. Default: ./.docker-data

# -----------------------------------------------------------------------------
# Security & CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173    # [Required] Allowed CORS origins (comma-separated). Default: http://localhost:5173
JWT_SECRET=change-me-to-a-strong-secret        # [Required] JWT signing secret. Default: change-me-to-a-strong-secret
JWT_EXPIRATION=3600                            # [Optional] JWT expiration in seconds. Default: 3600
