{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opengeobot.io/schemas/platform-feature-manifest.schema.json",
  "title": "OpenGeoBot platform feature manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline",
    "sources",
    "architecture_decisions",
    "architecture",
    "mandatory_done_evidence",
    "platform_capabilities",
    "platform_capability_profiles",
    "external_contracts",
    "features"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1"
    },
    "baseline": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "architecture_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^docs/adr/ADR-[0-9]{4}-.+\\.md$"
      },
      "uniqueItems": true
    },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cloud_backend",
        "frontend",
        "agent_runtime",
        "tool_protocol",
        "edge_runtime",
        "ros2",
        "ros1",
        "constrained_network",
        "database",
        "object_storage",
        "vector_database",
        "messaging",
        "monitoring",
        "logging",
        "alerting"
      ],
      "properties": {
        "cloud_backend": {
          "const": "JAVA21_SPRING_BOOT3_MYBATIS_PLUS_AND_PYTHON312"
        },
        "frontend": {
          "const": "VUE3_TYPESCRIPT_VITE_PRIMARY_REACT_ADR_ONLY_WEBSOCKET"
        },
        "agent_runtime": {
          "const": "QWENPAW_VIA_AGENT_RUNTIME_PROVIDER"
        },
        "tool_protocol": {
          "const": "MCP_PRIMARY_HTTP_GRPC_AUXILIARY"
        },
        "edge_runtime": {
          "const": "ROSCLAW_EDGE_RUNTIME"
        },
        "ros2": {
          "const": "ROS2_DDS_ROSBRIDGE_ZENOH_PRIMARY"
        },
        "ros1": {
          "const": "ROS1_BRIDGE_ROSBRIDGE_SUITE_CUSTOM_GATEWAY_COMPATIBILITY"
        },
        "constrained_network": {
          "const": "ZENOH"
        },
        "database": {
          "const": "POSTGRESQL_TIMESCALEDB_OPTIONAL"
        },
        "object_storage": {
          "const": "MINIO_S3"
        },
        "vector_database": {
          "const": "PGVECTOR"
        },
        "messaging": {
          "const": "NATS_JETSTREAM"
        },
        "monitoring": {
          "const": "VMAGENT_VICTORIAMETRICS_GRAFANA"
        },
        "logging": {
          "const": "VECTOR_LOKI_POSTGRESQL_AUDIT"
        },
        "alerting": {
          "const": "GRAFANA_ALERTING_OR_PLATFORM_ALARM_SERVICE"
        }
      }
    },
    "mandatory_done_evidence": {
      "type": "array",
      "minItems": 5,
      "items": {
        "enum": [
          "DEPLOYMENT",
          "OBSERVABILITY",
          "SECURITY_REPORTS",
          "TEST_REPORTS",
          "RUNBOOK"
        ]
      },
      "uniqueItems": true
    },
    "platform_capabilities": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Z][A-Z0-9_]+$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/featureId"
      }
    },
    "platform_capability_profiles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Z][A-Z0-9_]+$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/capabilitySet"
      }
    },
    "external_contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/externalContract"
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/feature"
      }
    }
  },
  "$defs": {
    "featureId": {
      "type": "string",
      "pattern": "^F-[A-Z]+-[0-9]{3}$"
    },
    "capabilitySet": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]+$"
      },
      "uniqueItems": true
    },
    "stringSet": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "pageIdSet": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^P-[A-Z]+-[A-Z0-9]+$"
      },
      "uniqueItems": true
    },
    "useCaseIdSet": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^UC-[A-Z]+-[A-Z0-9-]+$"
      },
      "uniqueItems": true
    },
    "stateMachineIdSet": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SM-[A-Z]+-[A-Z0-9-]+$"
      },
      "uniqueItems": true
    },
    "externalContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "official_source",
        "pin_status",
        "required_by"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^EXT-[A-Z0-9-]+$"
        },
        "official_source": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "pin_status": {
          "enum": [
            "UNPINNED",
            "PINNED"
          ]
        },
        "required_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/featureId"
          },
          "uniqueItems": true
        },
        "locked_reference": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "pin_status": {
                "const": "PINNED"
              }
            },
            "required": [
              "pin_status"
            ]
          },
          "then": {
            "required": [
              "locked_reference"
            ]
          }
        }
      ]
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "phase",
        "implementation_status",
        "source_sections",
        "platform_capability_profile",
        "deployment_targets",
        "frontend",
        "backend",
        "data",
        "security",
        "contracts",
        "events",
        "observability",
        "verification"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^F-[A-Z]+-[0-9]{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 2
        },
        "phase": {
          "enum": [
            "M0",
            "M1",
            "M2",
            "M3",
            "M4",
            "M5",
            "M6"
          ]
        },
        "implementation_status": {
          "enum": [
            "NOT_STARTED",
            "IN_PROGRESS",
            "DONE",
            "NOT_APPLICABLE"
          ]
        },
        "source_sections": {
          "$ref": "#/$defs/stringSet"
        },
        "platform_capability_profile": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "deployment_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "BUILD",
              "INFRA",
              "CLOUD_JAVA",
              "AGENT_PYTHON",
              "WEB",
              "EDGE",
              "SIM",
              "OBSERVABILITY",
              "KUBERNETES"
            ]
          },
          "uniqueItems": true
        },
        "frontend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "page_ids",
            "required_view_states"
          ],
          "properties": {
            "page_ids": {
              "$ref": "#/$defs/pageIdSet"
            },
            "required_view_states": {
              "type": "array",
              "items": {
                "enum": [
                  "INITIAL",
                  "LOADING",
                  "READY",
                  "EMPTY",
                  "PARTIAL",
                  "STALE",
                  "OFFLINE",
                  "FORBIDDEN",
                  "ERROR"
                ]
              },
              "uniqueItems": true
            }
          }
        },
        "backend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "modules",
            "use_case_ids"
          ],
          "properties": {
            "modules": {
              "$ref": "#/$defs/stringSet"
            },
            "use_case_ids": {
              "$ref": "#/$defs/useCaseIdSet"
            }
          }
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "owner_schemas",
            "tables",
            "state_machine_ids"
          ],
          "properties": {
            "owner_schemas": {
              "$ref": "#/$defs/stringSet"
            },
            "tables": {
              "$ref": "#/$defs/stringSet"
            },
            "state_machine_ids": {
              "$ref": "#/$defs/stateMachineIdSet"
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "risk_level",
            "permission_codes",
            "requires_edge_safety"
          ],
          "properties": {
            "risk_level": {
              "enum": [
                "R0_READ_ONLY",
                "R1_NON_MOTION",
                "R2_BOUNDED_MOTION",
                "R3_HIGH_RISK"
              ]
            },
            "permission_codes": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
              },
              "uniqueItems": true
            },
            "requires_edge_safety": {
              "type": "boolean"
            }
          }
        },
        "contracts": {
          "$ref": "#/$defs/stringSet"
        },
        "events": {
          "$ref": "#/$defs/stringSet"
        },
        "observability": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "AUDIT",
              "TRACE",
              "LOG",
              "METRIC",
              "ALARM"
            ]
          },
          "uniqueItems": true
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "acceptance_ids",
            "required_tests",
            "done_evidence"
          ],
          "properties": {
            "acceptance_ids": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^C(0[1-9]|1[0-9]|2[0-4])$"
              },
              "uniqueItems": true
            },
            "required_tests": {
              "type": "array",
              "minItems": 1,
              "items": {
                "enum": [
                  "UNIT",
                  "CONTRACT",
                  "INTEGRATION",
                  "COMPONENT",
                  "E2E",
                  "SIMULATION",
                  "SECURITY",
                  "RECOVERY",
                  "HIL"
                ]
              },
              "uniqueItems": true
            },
            "done_evidence": {
              "type": "array",
              "minItems": 1,
              "items": {
                "enum": [
                  "CONTRACTS",
                  "MIGRATIONS",
                  "BACKEND",
                  "FRONTEND",
                  "EVENTS",
                  "DEPLOYMENT",
                  "OBSERVABILITY",
                  "SECURITY_REPORTS",
                  "TEST_REPORTS",
                  "RUNBOOK",
                  "HIL_REPORT"
                ]
              },
              "uniqueItems": true
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "contracts": {
              "$ref": "#/$defs/stringSet"
            },
            "migrations": {
              "$ref": "#/$defs/stringSet"
            },
            "backend": {
              "$ref": "#/$defs/stringSet"
            },
            "frontend": {
              "$ref": "#/$defs/stringSet"
            },
            "events": {
              "$ref": "#/$defs/stringSet"
            },
            "deployment": {
              "$ref": "#/$defs/stringSet"
            },
            "observability": {
              "$ref": "#/$defs/stringSet"
            },
            "security_reports": {
              "$ref": "#/$defs/stringSet"
            },
            "test_reports": {
              "$ref": "#/$defs/stringSet"
            },
            "runbook": {
              "$ref": "#/$defs/stringSet"
            },
            "hil_report": {
              "$ref": "#/$defs/stringSet"
            }
          }
        },
        "not_applicable_reason": {
          "type": "string",
          "minLength": 10
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "implementation_status": {
                "const": "DONE"
              }
            },
            "required": [
              "implementation_status"
            ]
          },
          "then": {
            "required": [
              "evidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "implementation_status": {
                "const": "NOT_APPLICABLE"
              }
            },
            "required": [
              "implementation_status"
            ]
          },
          "then": {
            "required": [
              "not_applicable_reason"
            ]
          }
        }
      ]
    }
  }
}
