# =============================================================================
# OpenGeoBot .gitignore
# Time: 2026-07-03
# Author: AxeXie
# =============================================================================

# -----------------------------------------------------------------------------
# Java / Maven
# -----------------------------------------------------------------------------
target/
build/
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Maven Wrapper — keep wrapper jar, ignore downloader script
!.mvn/wrapper/maven-wrapper.jar
.mvn/wrapper/MavenWrapperDownloader.java

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
.vite/
*.local
*.tsbuildinfo
.npm/
.pnpm-store/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.venv-*/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage/
.nyc_output/

# Edge / sim runtime local state (offline cache, captured artifacts)
.edge-data/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.ctxt
.mtj.tmp/

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Docker / Infrastructure
# -----------------------------------------------------------------------------
.docker-data/
deploy/compose/.env

# Dev script PID/log artifacts
.dev-pids/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Test & Coverage
# -----------------------------------------------------------------------------
test-results/
playwright-report/
coverage-ui/

